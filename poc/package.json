{
  "name": "vkamp-poc",
  "version": "0.1.0",
  "description": "VKAmp POC tester — Electron + Svelte 5 proof-of-concept",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite build && electron .",
    "dev:mock": "VKAMP_MOCK=1 concurrently -k \"vite\" \"wait-on http://localhost:5173 && VKAMP_USE_DEV_SERVER=1 VKAMP_MOCK=1 electron .\"",
    "build": "vite build",
    "vite": "vite",
    "vite:build": "vite build",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "vite build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.0",
    "@fontsource/jetbrains-mono": "^5.0.0",
    "@fontsource/rajdhani": "^5.2.7",
    "electron-store": "^8.2.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "svelte": "^5.0.0",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.vkamp.poc",
    "productName": "VKAmp POC",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "main/**/*",
      "preload/**/*",
      "renderer/dist/**/*",
      "package.json",
      "!**/*.map",
      "!**/{.eslintrc,.editorconfig,.prettierrc,.babelrc}",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "VKAmp POC"
    }
  }
}
